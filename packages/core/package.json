{
  "name": "@linkedin-buddy/core",
  "version": "0.1.0",
  "description": "TypeScript LinkedIn automation library and shared local runtime for Playwright-backed LinkedIn workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigvardt/linkedin-buddy.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sigvardt/linkedin-buddy/issues"
  },
  "homepage": "https://github.com/sigvardt/linkedin-buddy/tree/main/packages/core",
  "keywords": [
    "linkedin",
    "linkedin-api",
    "linkedin-automation",
    "linkedin-toolkit",
    "linkedin-typescript",
    "playwright",
    "browser-automation",
    "library",
    "typescript",
    "nodejs",
    "sdk"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "fflate": "^0.8.2",
    "playwright-core": "^1.50.1",
    "playwright-extra": "^4.3.6",
    "pngjs": "^7.0.0",
    "proper-lockfile": "^4.1.2",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/pngjs": "^6.0.5",
    "@types/proper-lockfile": "^4.1.4"
  }
}
